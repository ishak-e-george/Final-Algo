## Ignore Visual Studio temporary files, build results, and user settings

# Build results
[Dd]ebug/
[Dd]ebugPS/
[Rr]elease/
[Rr]eleasePS/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
# wwwroot/lib/

# Visual Studio Code
.vscode/
*.code-workspace

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Mono Auto Generated Files
mono_crash.*

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# If hotpatching NuGet packages, feel free to remove this line
!**/[Pp]ackages/custom-package-location/
# Lookups/Indexes/Cache directories
**/[Pp]ackages/NuGet.Config
# NuGet.files is a backup of NuGet.config
**/[Pp]ackages/NuGet.files

# BUCK
.buckd/
buck-out/

# MSTest Resolve Assembly Reference Cache
BenchmarkDotNet.Artifacts/

# TASKS
*.tasks

# DB/LocalDB files
*.mdf
*.ldf
*.ndf

# JetBrains Rider
.idea/
*.sln.iml

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
