@model List<RescueFlow.Web.Models.Entities.Station>
@{
    ViewData["Title"] = "Rescue Stations Overview";
}

<div class="glass-card animated-fade">
    <div class="mb-4">
        <h1 class="h3 font-weight-700 text-white mb-1">🏢 Rescue Stations Directory</h1>
        <p class="text-secondary mb-0">Overview of active emergency dispatch centers, locations, and asset status.</p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 text-secondary">
            <span class="fs-1 d-block mb-2">🏢</span>
            <p class="mb-0">No rescue stations defined in database seed.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var s in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="glass-card h-100 mb-0 d-flex flex-column" style="background: rgba(255,255,255,0.02);">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h3 class="h5 text-white mb-0 font-weight-600">@s.Name</h3>
                                <span class="text-secondary fs-8 font-monospace">GPS: @s.Latitude, @s.Longitude</span>
                            </div>
                            <span class="badge bg-@(s.IsActive ? "success" : "danger") px-2 py-1 fs-9">
                                @(s.IsActive ? "ACTIVE" : "INACTIVE")
                            </span>
                        </div>

                        <div class="mt-auto">
                            <h4 class="fs-8 text-secondary font-weight-600 mb-2">Allocated Fleet (@s.Vehicles.Count)</h4>
                            @if (!s.Vehicles.Any())
                            {
                                <p class="text-muted fs-8 mb-0">No vehicles stationed here.</p>
                            }
                            else
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var v in s.Vehicles)
                                    {
                                        string statusColor = "secondary";
                                        if (v.Status == RescueFlow.Web.Models.Enums.VehicleStatus.Available) statusColor = "success";
                                        else if (v.Status == RescueFlow.Web.Models.Enums.VehicleStatus.Assigned) statusColor = "primary";
                                        else if (v.Status == RescueFlow.Web.Models.Enums.VehicleStatus.Maintenance) statusColor = "warning text-dark";

                                        <span class="badge bg-dark border border-secondary text-white fs-9 py-2 px-3 d-flex align-items-center gap-2">
                                            <span>🚒 @v.Code</span>
                                            <span class="badge bg-@statusColor" style="font-size: 0.65rem;">@v.Status</span>
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
